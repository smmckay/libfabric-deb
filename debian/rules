#!/usr/bin/make -f

# Cap LTO parallelism at link time. The default -flto=auto spawns nproc
# workers, which OOMs the GitHub-hosted ubuntu-22.04 runner (16 GB) when
# linking libfabric.so on amd64 with PSM3 whole-archived in. GCC honors the
# last -flto= on the link line, so append is sufficient — no need to strip.
export DEB_LDFLAGS_MAINT_APPEND = -flto=1

%:
	dh $@

override_dh_autoreconf:
	dh_autoreconf ./autogen.sh

UPSTREAM_VERSION := $(shell dpkg-parsechangelog -SVersion | sed 's/-.*//')

override_dh_auto_configure:
	dh_auto_configure -- \
		--enable-shared \
		--enable-static \
		--with-cuda=no \
		--enable-efa=yes \
		--enable-verbs=yes \
		$(EXTRA_CONFIGURE_FLAGS)

# psm3 fails to build in libfabric 1.12.0.
ifeq ($(UPSTREAM_VERSION),1.12.0)
override_dh_auto_configure: EXTRA_CONFIGURE_FLAGS += --disable-psm3
endif

# opx fails to build in libfabric 1.15.0 and 1.15.1
ifeq ($(UPSTREAM_VERSION),1.15.0)
override_dh_auto_configure: EXTRA_CONFIGURE_FLAGS += --disable-opx
endif
ifeq ($(UPSTREAM_VERSION),1.15.1)
override_dh_auto_configure: EXTRA_CONFIGURE_FLAGS += --disable-opx
endif

# Drop libtool archives — Debian policy disfavors them and they bake in
# build-time paths. Done before dh_install so dh_missing doesn't complain.
override_dh_auto_install:
	dh_auto_install
	find debian/tmp -name '*.la' -delete
