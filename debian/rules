#!/usr/bin/make -f

%:
	dh $@

override_dh_autoreconf:
	dh_autoreconf ./autogen.sh

override_dh_auto_configure:
	dh_auto_configure -- \
		--enable-shared \
		--enable-static \
		--with-cuda=no \
		--enable-efa=yes \
		--enable-verbs=yes

# Drop libtool archives — Debian policy disfavors them and they bake in
# build-time paths. Done before dh_install so dh_missing doesn't complain.
override_dh_auto_install:
	dh_auto_install
	find debian/tmp -name '*.la' -delete
